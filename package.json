{
  "name": "devpad",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint . --max-warnings=0",
    "preview": "vite preview",
    "preview:ci": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:preview": "node ./scripts/verify-preview.mjs",
    "validate:local": "npm run lint && npm test && npm run build && npm run verify:preview"
  },
  "dependencies": {
    "@codemirror/commands": "6.10.3",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/language": "6.12.2",
    "@codemirror/state": "6.6.0",
    "@codemirror/theme-one-dark": "6.1.3",
    "@codemirror/view": "6.40.0",
    "@lezer/highlight": "1.2.3",
    "codemirror": "6.0.2",
    "highlight.js": "11.11.1",
    "idb": "8.0.3",
    "lz-string": "1.5.0",
    "marked": "12.0.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.0",
    "eslint": "10.1.0",
    "fake-indexeddb": "6.2.5",
    "globals": "17.4.0",
    "jsdom": "29.0.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vite": "5.4.21",
    "vitest": "1.6.1"
  }
}
